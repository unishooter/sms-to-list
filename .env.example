# Backend
PORT=3001
HOST=127.0.0.1
DATABASE_PATH=./data/sms-list.sqlite

# Twilio
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_AUTH_TOKEN=

# Google OAuth (set CLIENT_ID to enable auth; leave blank to disable in dev)
GOOGLE_CLIENT_ID=

# Public URL used when validating Twilio signatures
PUBLIC_BASE_URL=https://lists.example.com
